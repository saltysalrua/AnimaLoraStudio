# Force CRLF on Windows scripts. cmd.exe parses .bat with LF-only line
# endings unreliably (often loads the whole file as one line, then exits
# silently -- looks like a "double-click and the window flashes closed" bug).
# Treat as binary -- keeps the raw CRLF bytes verbatim in the repo so
# `git pull` actually rewrites the working copy when the file changes.
# `text eol=crlf` would only convert on checkout, leaving stale LF working
# copies untouched (the bug that caused the silent double-click crash).
*.bat binary
*.cmd binary

# PowerShell tolerates LF on modern Windows; keep normalization.
*.ps1 text eol=crlf

# Shell scripts must use LF; CRLF breaks shebang and bash parsing on Linux.
*.sh text eol=lf

# ============================================================================
# Git LFS 追踪规则 —— CNB 环境持久化
#
# 底模权重是大文件（几 GB），通过 LFS 在新环境中恢复。
# 训练数据和输出 LoRA 不走 LFS，按需上传/下载即可。
# ============================================================================

# ---- 模型权重（models/ 目录，.gitignore 有对应 !models/** 例外规则）----
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.ckpt         filter=lfs diff=lfs merge=lfs -text
*.bin          filter=lfs diff=lfs merge=lfs -text
*.pt           filter=lfs diff=lfs merge=lfs -text
*.pth          filter=lfs diff=lfs merge=lfs -text
*.onnx         filter=lfs diff=lfs merge=lfs -text

# ---- VAE latent 缓存 ----
*.npz          filter=lfs diff=lfs merge=lfs -text

